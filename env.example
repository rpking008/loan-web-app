# ── SwiftLoan Backend Environment Variables ──
# Copy this file to .env and fill in your actual values

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Anthropic API (for AI KYC verification)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── KYC Provider APIs (for production) ──

# NSDL / UTI PAN Verification
NSDL_API_KEY=your_nsdl_api_key
NSDL_API_URL=https://api.nsdl.co.in/v1/pan/verify

# UIDAI Aadhaar (via licensed KYC partners only)
# Official route: UIDAI Authentication API via AUA/KUA partner
UIDAI_AUA_CODE=your_aua_code
UIDAI_ASA_CODE=your_asa_code
UIDAI_API_URL=https://developer.uidai.gov.in/authserver/2.0

# Face Match API
# Recommended: AWS Rekognition / Azure Face / DigiLocker Face Auth
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1

# CIBIL / Experian Credit Bureau
CIBIL_API_KEY=your_cibil_key
CIBIL_API_URL=https://api.cibil.com/v1/credit-report

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/swiftloan

# File Storage (AWS S3 for production document storage)
AWS_S3_BUCKET=swiftloan-kyc-docs
AWS_S3_REGION=ap-south-1

# JWT Secret (for auth tokens)
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# Notification Services
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890
SENDGRID_API_KEY=your_sendgrid_key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
